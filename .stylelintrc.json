{
  "extends": [
    "stylelint-config-standard",
    "stylelint-config-recess-order"
  ],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": ["theme", "tailwind", "apply", "variants", "responsive", "screen"]
      }
    ],
    "no-descending-specificity": null
  }
}